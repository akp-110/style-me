ANTHROPIC_API_KEY="Your Anthropic API Key here"
OPENWEATHER_API_KEY="Your OpenWeather API Key here"
VITE_SUPABASE_URL="Your Supabase URL here"
VITE_SUPABASE_ANON_KEY="Your Supabase Anon Key here"

# RapidAPI for product search (optional - mock data used if not set)
# Get free key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-product-search
RAPIDAPI_KEY="Your RapidAPI key here"

# Server-side only (rate limiting) — never VITE_-prefixed
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_secret_key
# Required: at least 32 random characters; used as the HMAC key for guest IPs
GUEST_IP_SALT=replace_with_at_least_32_random_characters

# Comma-separated exact browser origins. No wildcard is accepted in production.
APP_ORIGINS=http://localhost:5173

# Emergency cost-control kill switch; set to 1 to return 503 before quota/provider calls
DISABLE_AI_ENDPOINTS=0
